# Copy this file to .env.local and fill values locally.
# Never commit .env.local or any real key.

# Public browser configuration. These values are browser-exposed by design;
# use a publishable key (recommended) or the legacy anon key, never a secret key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional backward-compatible alternative when a publishable key is unavailable:
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Explicit runtime modes. These local defaults require no cloud credentials.
APP_DATA_MODE=demo
MERCHANT_DRAFT_PROVIDER=rules

# Production merchant AI (server only). On Vercel, AI Gateway uses the project's
# OIDC token automatically; configure an OpenAI BYOK integration in AI Gateway.
# APP_DATA_MODE=supabase
# MERCHANT_DRAFT_PROVIDER=ai-gateway
# MERCHANT_AI_MODEL=openai/<model-id>
# AI_GATEWAY_API_KEY=  # Optional for local/non-Vercel Gateway calls

# Server-only secrets — never prefix these with NEXT_PUBLIC_
# Prefer a scoped sb_secret_ key for this Vercel backend.
SUPABASE_SECRET_KEY=
# Legacy fallback only while migrating an older project:
# SUPABASE_SERVICE_ROLE_KEY=
